# 数据库：MVP一期默认 SQLite（零基础设施即可运行），代码保持 Postgres 可移植
# Postgres 示例： postgresql+asyncpg://user:pass@localhost:5432/scenario_review
DATABASE_URL=sqlite+aiosqlite:///./scenario_review.db

# JWT
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# 多租户：MVP一期单租户默认值
DEFAULT_TENANT_ID=t-default

# CORS（前端开发地址）
CORS_ORIGINS=http://localhost:3100
